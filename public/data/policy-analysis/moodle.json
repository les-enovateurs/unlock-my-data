        "status": "oui",
        "quote": "Our independent Data Protection Officer is:\n\nData Compliance Europe Ltd.\n12 City Gate\nLower Bridge Street, Dublin 8\nIreland\n\nEmail: dpo@moodle.com",
        "quote_verified": true,
