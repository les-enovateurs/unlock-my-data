      {
        "id": "pdp_data_types",
        "label": "Types de données collectées + raison",
        "status": "oui",
        "quote": "‘Personal data’, in this privacy notice, means any information that relates to an identified or identifiable natural person, such as a name, an identification number, location data, or online identifiers (including cookies).",
